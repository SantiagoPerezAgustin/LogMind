# Copiá este archivo como ".env" y completá los valores (no subas .env a Git).

# Puerto del servidor HTTP
PORT=3000

# PostgreSQL — reemplazá usuario, contraseña y nombre de base
DATABASE_URL=postgresql://postgres:TU_PASSWORD@localhost:5432/logmind

# Opcional: carpeta de uploads (por defecto: ./uploads respecto a la raíz del proyecto)
# UPLOAD_DIR=

# Mistral (La Plateforme) — clave en https://console.mistral.ai/
MISTRAL_API_KEY=
# Opcional: modelo (por defecto mistral-small-latest)
# MISTRAL_MODEL=mistral-small-latest

# Origen del front (Vite) para CORS
# CORS_ORIGIN=http://localhost:5173
